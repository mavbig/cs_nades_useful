generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Lineup {
  id             String    @id @default(uuid())
  map            String
  side           String    // "T", "CT", "ANY"
  utility        String    // "SMOKE", "FLASH", "MOLLY", "HE", "DECOY"
  title          String
  description    String?
  tags           String    // Comma-separated
  startSpot      String
  throwType      String    // "STAND", "WALK", "RUN", "JUMPTHROW", "A JUMPTHROW", "D JUMPTHROW", "RUN JUMPTHROW", "WALK JUMPTHROW", "RIGHT CLICK", "LEFT+RIGHT CLICK"
  tickrate       String    // "TR64", "TR128", "ANY"
  screenshotPath String
  clipPath       String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([map])
}
